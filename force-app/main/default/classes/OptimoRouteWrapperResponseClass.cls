/**
 * @description Wrapper class used to deserialize the JSON response from Optimo Route.
 * This class captures the overall transaction status and individual processing results
 * for each order sent in a bulk request.
 */
public with sharing class OptimoRouteWrapperResponseClass {
    
    public boolean success; // Indicates if the overall API request was accepted and processed
    public String code; // API specific response code (e.g., "ERR_VALIDATION" or "SUCCESS")
    public String message; // Human-readable message explaining the response status or error details
    public List<cls_orders> orders; // List of results for each individual order included in the request

	/**
     * @description Inner class representing the response data for a single order.
     */
	public class cls_orders {
		public String orderNo;	// The unique identifier provided by Salesforce (e.g., WorkOrderNumber)
		public String id;	// The unique Internal ID generated by Optimo Route for this order
		public boolean success; // Indicates if this specific order was successfully created/updated in Optimo
	}

}