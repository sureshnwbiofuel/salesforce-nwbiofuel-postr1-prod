    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_WO_Record</name>
        <label>Create WO Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Call_Optimo_Batch_Class</targetReference>
        </connector>
        <inputReference>newWORecord</inputReference>
    </recordCreates>
    <recordUpdates>
        <name>Update_Service_Date_SN</name>
        <label>Update Service Date SN</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Create_WO_Record</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>originalWORecord.Services_Needed__c</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Due_Date__c</field>
            <value>
                <elementReference>newDueDate</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Last_Collected_Gallons__c</field>
            <value>
                <elementReference>originalWORecord.Collected_Gallons__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Last_Completed_Date__c</field>
            <value>
                <elementReference>originalWORecord.Optimo_Date__c</elementReference>
            </value>
        </inputAssignments>
        <object>Services_Needed__c</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Status</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <subflows>
        <name>Get_User_Emails</name>
