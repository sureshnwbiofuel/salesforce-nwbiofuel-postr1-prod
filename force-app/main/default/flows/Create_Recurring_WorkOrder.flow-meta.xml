    <decisions>
        <name>Check_Completed</name>
        <label>Check Completed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Create_WO_Record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Post_Creation_Completed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>originalWORecord.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Service_Date_SN</targetReference>
            </connector>
            <label>Completed</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Status</name>
        <label>Check Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Completed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Completed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_New_WO_Values</targetReference>
            </connector>
            <label>Completed</label>
        </rules>
        <rules>
            <name>Rejected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Rejected</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>New_Rejected_WO_Values</targetReference>
            </connector>
            <label>Rejected</label>
        </rules>
        <rules>
            <name>Failed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Failed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Failed_WO_Values</targetReference>
            </connector>
            <label>Failed</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Users_Exists</name>
        <label>Check Users Exists</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Completed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_User_Emails.listOfEmailIds</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Iterate_List_Of_Email_Ids</targetReference>
            </connector>
            <label>Exists</label>
        </rules>
    </decisions>
    <description>Create Recurring WorkOrders for Statuses Completed/Failed/Rejected</description>
    <environments>Default</environments>
    <formulas>
        <name>forBaseURL</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_340}, FIND(&quot;/services&quot;, {!$Api.Partner_Server_URL_340}))</expression>
    </formulas>
    <formulas>
        <name>forLinkAccount</name>
        <dataType>String</dataType>
        <expression>{!forBaseURL}&amp;{!originalWORecord.AccountId}</expression>
    </formulas>
    <formulas>
        <name>forLinkServiceNeeded</name>
        <dataType>String</dataType>
        <expression>{!forBaseURL} &amp; {!originalWORecord.Services_Needed__c}</expression>
    </formulas>
    <formulas>
        <name>forLinkWorkOrder</name>
        <dataType>String</dataType>
        <expression>{!forBaseURL}&amp;{!originalWORecord.Id}</expression>
    </formulas>
    <formulas>
        <name>newDueDate</name>
        <dataType>Date</dataType>
        <expression>{!originalWORecord.Optimo_Date__c} + {!originalWORecord.Services_Needed__r.Frequency_Days__c}</expression>
    </formulas>
    <formulas>
        <name>newOrderDate</name>
        <dataType>Date</dataType>
        <expression>{!originalWORecord.Optimo_Date__c} + 1</expression>
    </formulas>
    <formulas>
        <name>serviceNeededRecordType</name>
        <dataType>String</dataType>
        <expression>CASE(
{!originalWORecord.Services_Needed__r.RecordType.DeveloperName},
&quot;Grease_Trap&quot;, &quot;IGT&quot;,
&quot;Drain_Cleaning&quot;, &quot;HYD&quot;,
&quot;Interceptor&quot;, &quot;EGT&quot;,
&quot;Used_Cooking_Oil&quot;, &quot;UCO&quot;,
&quot;Waste_Run&quot;,&quot;WR&quot;,
&quot;&quot;
)</expression>
    </formulas>
    <interviewLabel>Create Recurring WorkOrder {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Create Recurring WorkOrder</label>
    <loops>
        <name>Iterate_List_Of_Email_Ids</name>
        <label>Iterate List Of Email Ids</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_User_Emails.listOfEmailIds</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_Email_Ids</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>sendNotificationForOriginalWO</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
