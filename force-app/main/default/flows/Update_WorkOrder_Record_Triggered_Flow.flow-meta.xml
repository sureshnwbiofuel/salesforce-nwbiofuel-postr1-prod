            </conditions>
            <conditions>
                <leftValueReference>$Record.Secondary_Time_Window_To__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Time_Window_Error_Message</targetReference>
            </connector>
            <label>Check Time Window</label>
        </rules>
        <rules>
            <name>Blank_Account_Number_Update</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.AccountNumber</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Blank_Account_Number_Error_Message</targetReference>
            </connector>
